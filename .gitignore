# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# classical text source files (PDFs, raw text)
/data/texts/
ephe/
.superpowers/

# SEO audit tokens & reports
.gsc-token.json
/reports/

# Playwright test artifacts
test-results/
.playwright-mcp/
final_stress_test.ts

# GSC daily indexing cron — runtime state + logs (regenerated by every run)
scripts/gsc-rotation-state.json
scripts/gsc-daily-cron.log
scripts/.gsc-request-indexing.json

# Media files (too large for git)
public/videos/*.mp4
*.mp3
*.mp4
*.wav
*.zip
scripts/video/*/voice-samples/
scripts/video-assets/
.claude/worktrees/
art-sources/

# laptop-side SEO verification timelines (created on first run)
scripts/output/staleness-verify-timeline.jsonl
scripts/output/gsc-recovery-timeline.jsonl

# Precompute pipeline (data only; code lives in scripts/precompute and src/lib/precompute)
data/precompute/

# Materialised launchd plists (have user-specific absolute paths)
scripts/precompute-cost-check-*.plist
scripts/precompute-daily-cron-*.plist
scripts/com.dekhopanchang.*.plist
# Run logs from local scripts
scripts/precompute-cost-check.log
scripts/precompute-daily-cron.log
scripts/precompute-local.log
