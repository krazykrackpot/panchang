{
  "rewrites": [
    {
      "source": "/:path*/_next/:asset*",
      "destination": "/_next/:asset*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/generate-notifications",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/email-alerts",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/transit-alerts",
      "schedule": "0 6 * * 0"
    }
  ]
}
