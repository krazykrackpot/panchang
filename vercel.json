{
  "rewrites": [
    {
      "source": "/:path*/_next/:asset*",
      "destination": "/_next/:asset*"
    }
  ],
  "functions": {
    "src/app/api/kundali-report/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/chart-chat/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/tippanni-llm/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/ai-reading/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/panchang-pdf/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/cron/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/api/**/*.ts": {
      "maxDuration": 10
    },
    "src/app/api/**/*.tsx": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/cron/generate-notifications",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/email-alerts",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/transit-alerts",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/cron/daily-panchang",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/onboarding-drip",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/domain-activations",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/cron/monthly-readings",
      "schedule": "0 2 1 * *"
    },
    {
      "path": "/api/cron/index-urls",
      "schedule": "5 0 * * *"
    }
  ]
}
