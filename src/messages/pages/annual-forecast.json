  "mahaChanging": {
    "en": "Major Dasha Transition This Year",
    "hi": "इस वर्ष महादशा परिवर्तन",
    "ta": "இந்த ஆண்டு மகா தசா மாற்றம்",
    "te": "ఈ సంవత్సరం మహాదశ మార్పు",
    "bn": "এই বছর মহাদশা পরিবর্তন",
    "kn": "ಈ ವರ್ಷ ಮಹಾದಶಾ ಬದಲಾವಣೆ",
    "mr": "या वर्षी महादशा बदल",
    "gu": "आ वर्ष महादशा फेरफार",
    "mai": "ई वर्ष महादशा परिवर्तन",
    "sa": "Major Dasha Transition This Year"
  },
  "mahaChangingDesc": {
    "en": "A Maha Dasha change brings a fundamental shift in life themes. Prepare for new directions.",
    "hi": "महादशा परिवर्तन जीवन में मूलभूत बदलाव लाता है। नई दिशाओं के लिए तैयार रहें।",
    "ta": "மகா தசா மாற்றம் வாழ்க்கையில் அடிப்படை மாற்றங்களைக் கொண்டுவரும். புதிய திசைகளுக்குத் தயாராகுங்கள்.",
    "te": "మహాదశ మార్పు జీవితంలో మౌలిక మార్పులను తెస్తుంది. కొత్త దిశలకు సిద్ధంగా ఉండండి.",
    "bn": "মহাদশা পরিবর্তন জীবনে মৌলিক পরিবর্তন আনে। নতুন দিকনির্দেশনার জন্য প্রস্তুত থাকুন।",
    "kn": "ಮಹಾದಶಾ ಬದಲಾವಣೆ ಜೀವನದಲ್ಲಿ ಮೂಲಭೂತ ಬದಲಾವಣೆಗಳನ್ನು ತರುತ್ತದೆ. ಹೊಸ ದಿಕ್ಕುಗಳಿಗೆ ಸಿದ್ಧರಾಗಿ.",
    "mr": "महादशा बदल जीवनात मूलभूत बदल घडवतो. नवीन दिशांसाठी तयार रहा.",
    "gu": "મहादशा फेरफार जीवनमां मूळभूत बदलाव लावे छे. नवी दिशाओ माटे तैयार रहो.",
    "mai": "महादशा परिवर्तन जीवनमे मूलभूत बदलाव अनैत अछि। नव दिशाक लेल तैयार रहू.",
    "sa": "A Maha Dasha change brings a fundamental shift in life themes. Prepare for new directions."
  },
