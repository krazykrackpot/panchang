#!/bin/sh
# Pre-commit: TypeScript type-check + locale key parity.
# Fails fast and locally before work even leaves the box.

# Skip on --no-verify or if commit is empty
if [ -n "$GIT_NO_VERIFY" ]; then
  exit 0
fi

# Only check staged .ts/.tsx files to keep this fast
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | grep -v node_modules)
STAGED_JSON=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'src/messages/.*\.json$')

if [ -z "$STAGED_TS" ] && [ -z "$STAGED_JSON" ]; then
  exit 0
fi

echo "Pre-commit checks:"

# 1. TypeScript type-check (project-wide — fast with incremental)
if [ -n "$STAGED_TS" ]; then
  echo "  [1/2] tsc --noEmit..."
  NODE_OPTIONS="--max-old-space-size=6144" npx tsc --noEmit -p tsconfig.build-check.json 2>&1
  if [ $? -ne 0 ]; then
    echo ""
    echo "COMMIT BLOCKED: TypeScript errors. Fix before committing."
    echo "  (bypass with: git commit --no-verify — use sparingly)"
    exit 1
  fi
fi

# 2. Banned patterns — catch bugs that rules alone don't prevent
if [ -n "$STAGED_TS" ]; then
  echo "  [2/3] banned pattern scan..."
  VIOLATIONS=""

  # Ban: re-deriving nakshatra from longitude in kundali components/narrative
  # (dasha files are exempt — they need fractional position within nakshatra)
  # `/dev/null` is appended so that if xargs receives zero files, grep
  # still has a real file argument and exits 1 instead of hanging on stdin.
  BAD_NAK=$(echo "$STAGED_TS" | grep -E '(chart-narrative|SummaryView|chakra-systems|tippanni|vedic-profile)' | xargs grep -ln 'Math.floor.*360.*27.*+ 1' /dev/null 2>/dev/null | grep -v 'nakshatra?.id ??')
  if [ -n "$BAD_NAK" ]; then
    VIOLATIONS="${VIOLATIONS}\n  ⚠ Re-derived nakshatra from longitude (use .nakshatra.id): $BAD_NAK"
  fi

  # Ban: browser timezone for panchang time comparison
  BAD_TZ=$(echo "$STAGED_TS" | grep -v 'now-in-timezone' | xargs grep -ln 'getHours().*\* 60\|getHours() \* 60' /dev/null 2>/dev/null)
  if [ -n "$BAD_TZ" ]; then
    VIOLATIONS="${VIOLATIONS}\n  ⚠ Browser timezone used for time comparison (use nowMinutesInTimezone): $BAD_TZ"
  fi

  if [ -n "$VIOLATIONS" ]; then
    echo ""
    echo "COMMIT BLOCKED: Banned patterns detected:"
    echo -e "$VIOLATIONS"
    echo ""
    echo "  (bypass with: git commit --no-verify — document why)"
    exit 1
  fi
fi

# 2b. ISR hydration audit — only when staged files include either an ISR
# page or a Client component (where the bug lives). Compares against the
# baseline; only NEW render-scope clock calls block the commit. See
# CLAUDE.md Lesson ZD for context.
STAGED_HYDRATION_RISK=$(echo "$STAGED_TS" | grep -E '(src/app/\[locale\]/.*page\.tsx|Client\.(ts|tsx)$)')
if [ -n "$STAGED_HYDRATION_RISK" ]; then
  echo "  [2b/3] ISR hydration audit (vs baseline)..."
  npx tsx scripts/audit-isr-hydration.ts --baseline 2>&1
  AUDIT_EXIT=$?
  if [ $AUDIT_EXIT -ne 0 ]; then
    echo ""
    echo "COMMIT BLOCKED: NEW render-scope clock call(s) on ISR route detected."
    echo "  See CLAUDE.md Lesson ZD for the three acceptable fix patterns."
    echo "  To intentionally accept (NOT recommended), update the baseline:"
    echo "    npx tsx scripts/audit-isr-hydration.ts --update-baseline"
    echo "  (bypass with: git commit --no-verify — document why)"
    exit 1
  fi
fi

# 3. Locale key parity — every locale must have the same top-level keys as en
if [ -n "$STAGED_JSON" ] || [ -n "$STAGED_TS" ]; then
  echo "  [2/2] locale key parity..."
  node -e "
  const fs = require('fs');
  const path = require('path');
  const dir = 'src/messages';
  const locales = fs.readdirSync(dir).filter(n => fs.statSync(path.join(dir, n)).isDirectory());
  if (!locales.includes('en')) process.exit(0);
  const files = ['global.json', 'pages.json', 'components.json', 'learn.json'];
  let failed = false;
  for (const f of files) {
    const enPath = path.join(dir, 'en', f);
    if (!fs.existsSync(enPath)) continue;
    const en = JSON.parse(fs.readFileSync(enPath, 'utf8'));
    const enKeys = new Set(Object.keys(en));
    for (const loc of locales) {
      if (loc === 'en') continue;
      const p = path.join(dir, loc, f);
      if (!fs.existsSync(p)) { console.error('    MISSING FILE:', p); failed = true; continue; }
      const data = JSON.parse(fs.readFileSync(p, 'utf8'));
      const missing = [...enKeys].filter(k => !(k in data));
      if (missing.length) {
        console.error(\`    \${loc}/\${f}: missing top-level keys: \${missing.join(', ')}\`);
        failed = true;
      }
    }
  }
  process.exit(failed ? 1 : 0);
  " 2>&1
  if [ $? -ne 0 ]; then
    echo ""
    echo "COMMIT BLOCKED: locale key parity failure. Add missing keys to all locales."
    echo "  (bypass with: git commit --no-verify)"
    exit 1
  fi
fi

# 4. Scaffolded 9-locale data tables — auto-sync overlay via Gemini when
# AUTHORED_EN/HI changes. See CLAUDE.md i18n section + PR #580.
STAGED_OVERLAY_TS=$(echo "$STAGED_TS" | xargs grep -l -E "from '@/lib/constants/[a-z0-9][a-z0-9-]*-overlay\.json'" /dev/null 2>/dev/null)
if [ -n "$STAGED_OVERLAY_TS" ]; then
  echo "  [4/5] locale overlay sync..."
  python3 scripts/sync-locale-overlays.py $STAGED_OVERLAY_TS
  if [ $? -ne 0 ]; then
    echo ""
    echo "COMMIT BLOCKED: locale overlay sync failed. See message above."
    echo "  (bypass with: git commit --no-verify — run translator manually before pushing)"
    exit 1
  fi
fi

# 5. Parana cross-reference audit — Drik-derived golden values. Triggered
# only when files in the astronomical / calendar pipeline are touched, so
# unrelated PRs don't pay the cost. See CLAUDE.md "Definition of Done" #5
# and Lesson K. Fixture: src/lib/calendar/__fixtures__/parana-drik-references.json.
STAGED_ASTRO=$(echo "$STAGED_TS" | grep -E '^src/lib/(calendar|ephem|kundali/yoga|panchang)/' | head -20)
if [ -n "$STAGED_ASTRO" ]; then
  echo "  [5/5] parana cross-reference audit (Drik)..."
  npx tsx scripts/audit-parana-vs-references.ts
  if [ $? -ne 0 ]; then
    echo ""
    echo "COMMIT BLOCKED: parana audit failed. Astronomical/panchang change drifted"
    echo "  beyond ±2m of curated Drik Panchang reference. See message above."
    echo "  (bypass with: git commit --no-verify — document why the drift is intentional)"
    exit 1
  fi
fi

echo "Pre-commit OK."
