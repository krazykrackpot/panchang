# ============================================
# Jyotish Panchang — Environment Variables
# ============================================

# Public URL (used for sitemap, OG tags, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://jyotishpanchang.com

# Supabase (required for user accounts & saved charts)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (optional — for RAG classical text synthesis)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Payment — Razorpay (India)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PRO_MONTHLY=
RAZORPAY_PLAN_PRO_ANNUAL=
RAZORPAY_PLAN_JYOTISHI_MONTHLY=
RAZORPAY_PLAN_JYOTISHI_ANNUAL=

# Payment — Stripe (International)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_JYOTISHI_MONTHLY=
STRIPE_PRICE_JYOTISHI_ANNUAL=

# Google AdSense (optional — for free-tier ad monetization)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
