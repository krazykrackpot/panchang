{
  "name": "panchang-setup",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 3000",
    "dev:turbo": "NODE_OPTIONS='--max-old-space-size=8192' next dev --turbopack -p 3000",
    "dev:clean": "rm -rf .next && next dev --webpack -p 3000",
    "build": "npx supabase db push --project-ref qtxbbeyjvkhvciseswpr 2>/dev/null || true && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --reporter=verbose src/lib/",
    "test:integration": "vitest run --reporter=verbose tests/integration/",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:all": "vitest run --reporter=verbose && npx playwright test",
    "e2e:seed": "node --env-file=.env.local --import tsx scripts/e2e-seed.ts",
    "test:e2e:auth": "E2E_AUTH_COOKIE=\"$(npm run -s e2e:seed -- --token-only)\" npx playwright test e2e/dashboard-saved-kundalis.spec.ts e2e/error-surfacing.spec.ts",
    "analyze": "ANALYZE=true next build --webpack"
  },
  "dependencies": {
    "@react-email/components": "^1.0.11",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@supabase/supabase-js": "^2.100.0",
    "@types/three": "^0.184.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.6.0",
    "next-intl": "^4.8.3",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.10.0",
    "stripe": "^21.0.1",
    "sweph": "^2.10.3-b-1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "next": "^16.2.4",
    "pdf-parse": "^2.4.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
