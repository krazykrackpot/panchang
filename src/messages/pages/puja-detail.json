  "comingSoon": {
    "en": "Puja Vidhi coming soon",
    "hi": "पूजा विधि शीघ्र आ रही है",
    "sa": "पूजाविधिः शीघ्रम् आगच्छति",
    "ta": "பூஜை விதி விரைவில் வரும்",
    "te": "పూజా విధి త్వరలో వస్తుంది",
    "bn": "পূজা বিধি শীঘ্রই আসছে",
    "kn": "ಪೂಜಾ ವಿಧಿ ಶೀಘ್ರದಲ್ಲೇ ಬರಲಿದೆ",
    "gu": "પૂજા વિધિ ટૂંક સમયમાં આવશે",
    "mai": "पूजा विधि शीघ्र आबि रहल अछि",
    "mr": "पूजा विधी लवकरच येत आहे"
  },
  "comingSoonDesc": {
    "en": "This puja vidhi is being prepared. Please check back later.",
    "hi": "यह पूजा विधि तैयार की जा रही है। कृपया बाद में देखें।",
    "sa": "इयं पूजाविधिः सज्जीक्रियते। कृपया पश्चात् पश्यतु।",
    "ta": "இந்த பூஜை விதி தயாரிக்கப்படுகிறது. பின்னர் பார்க்கவும்.",
    "te": "ఈ పూజా విధి తయారవుతోంది. దయచేసి తర్వాత చూడండి.",
    "bn": "এই পূজা বিধি প্রস্তুত করা হচ্ছে। পরে দেখুন।",
    "kn": "ಈ ಪೂಜಾ ವಿಧಿ ಸಿದ್ಧಪಡಿಸಲಾಗುತ್ತಿದೆ. ದಯವಿಟ್ಟು ನಂತರ ನೋಡಿ.",
    "gu": "આ પૂજા વિધિ તૈયાર કરવામાં આવી રહી છે. કૃપા કરીને પછી જુઓ.",
    "mai": "ई पूजा विधि तैयार कएल जा रहल अछि। कृपया बादमे देखू.",
    "mr": "ही पूजा विधी तयार केली जात आहे. कृपया नंतर पहा."
  },
